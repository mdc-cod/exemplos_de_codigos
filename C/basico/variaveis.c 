#include <stdio.h>

int main(){

  int valor_int = 5; // tipo inteiro
  float valor_float = 5.1; // tipo float
  double valor_double = 5.1; // tipo double 
  char caractere = 'a'; // tipo char  

  printf("inteiro: %d\n", valor_int);
  printf("float: %f\ndouble: %f\n", valor_float, valor_double);
  printf("char: %c\n", caractere);

  return 0;

}
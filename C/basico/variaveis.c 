#include <stdio.h>

int main(){

  // tipos de variaveis 
  int valor_int = 5;
  float valor_float = 5.1;
  double valor_double = 5.1; 
  char caractere = 'a';

  printf("inteiro: %d\n", valor_int);
  printf("float: %f\ndouble: %f\n", valor_float, valor_double);
  printf("char: %c\n", caractere);

  return 0;

}